{
  "type": "panel",
  "items": {
    "apiToken": {
      "type": "password",
      "label": "API-Token",
      "help": "Token aus den erweiterten Einstellungen der my-PV Cloud (Aktivierung kann bis zu 10 Minuten dauern)",
      "sm": 12,
      "validator": "!data.apiToken || data.apiToken.length > 10",
      "validatorErrorText": "Bitte einen gültigen API-Token eingeben"
    },
    "_divider1": {
      "type": "divider"
    },
    "serialNumber": {
      "type": "text",
      "label": "Seriennummer des Geräts",
      "help": "Seriennummer des AC ELWA 2 / AC·THOR / AC·THOR 9s",
      "sm": 12
    },
    "_divider2": {
      "type": "divider"
    },
    "_header_polling": {
      "type": "header",
      "text": "Polling-Einstellungen"
    },
    "pollInterval": {
      "type": "number",
      "label": "Abfrageintervall (Sekunden)",
      "help": "Wie oft sollen die Daten abgerufen werden? (Minimum: 10 Sekunden)",
      "min": 10,
      "max": 3600,
      "default": 60,
      "sm": 6
    },
    "_divider3": {
      "type": "divider"
    },
    "_header_data": {
      "type": "header",
      "text": "Datenabruf"
    },
    "fetchDeviceStatus": {
      "type": "checkbox",
      "label": "Gerätestatus abrufen (/device/{sn}/status)",
      "default": true,
      "sm": 12
    },
    "fetchPowerData": {
      "type": "checkbox",
      "label": "Leistungsdaten abrufen (/device/{sn}/power)",
      "default": true,
      "sm": 12
    }
  }
}
